# =============================================================================
# Demo configuration — copy to .env and fill in. NEVER commit .env to git.
# =============================================================================
# All scripts and the React app read from these. Set them once here
# instead of editing every file individually.
#
# Quickstart for a fresh account:
#   1. cp .env.example .env
#   2. Fill in SNOWFLAKE_CONNECTION + the cloudflared/ingest values.
#   3. Run:  ./deploy-app.sh --bootstrap
#      This provisions the database/schema/warehouses/IT/role/EAI/agent
#      via setup.sql + semantic_view.sql, then deploys the Snowflake App.

# -----------------------------------------------------------------------------
# Snowflake account
# -----------------------------------------------------------------------------
# Your `snow connection list` connection name (the one with ACCOUNTADMIN)
SNOWFLAKE_CONNECTION=<your-connection>

# Snowflake account locator (from `snow connection list` -> "account")
SNOWFLAKE_ACCOUNT=<your-snowflake-account>

# -----------------------------------------------------------------------------
# App object names (defaults match the canonical SE-demo deployment;
# override only if you want different names in your account).
# These flow through to setup.sql, semantic_view.sql, web/snowflake.yml,
# and the React app at build time via NEXT_PUBLIC_* mirrors below.
# -----------------------------------------------------------------------------
APP_DB=SNOWFLAKE_EXAMPLE
APP_SCHEMA=CREDIT_DEMO
INTERACTIVE_WH=CREDIT_DEMO_INT_WH
STANDARD_WH=CREDIT_DEMO_WH
INGEST_ROLE=CREDIT_INGEST_RL
DASHBOARD_ROLE=DASHBOARD_RL
DASHBOARD_POOL=DASHBOARD_POOL
DASHBOARD_APP_NAME=CREDIT_DASHBOARD
DASHBOARD_EAI=DASHBOARD_VM_EAI
INGEST_NETWORK_RULE=DASHBOARD_INGEST_RULE
APP_CONFIG_TABLE=APP_CONFIG
AGENT_NAME=CREDIT_AGENT
SEMANTIC_VIEW_NAME=CREDIT_SEMANTIC_VIEW
SEARCH_SERVICE_NAME=CREDIT_SEARCH_SVC
INGEST_STAGE=CREDIT_STAGE

# -----------------------------------------------------------------------------
# GCP VM (Snowpipe Streaming HPA producer host)
# -----------------------------------------------------------------------------
VM_NAME=<your-vm-name>
VM_ZONE=us-central1-c
# Static NAT IP of the VM (used for the network-policy CIDR allow-list)
VM_STATIC_IP=<your-vm-static-ip>

# -----------------------------------------------------------------------------
# Cloudflare tunnel
# -----------------------------------------------------------------------------
# Public DNS hostname routed to VM:8080 via cloudflared (e.g. ingest.example.com)
INGEST_TUNNEL_HOST=<your-tunnel-host>

# Cloudflare Tunnel token (Path 1 — compose-embedded tunnel)
# Create a tunnel at https://one.dash.cloudflare.com → Networks → Tunnels,
# then paste the token here. Leave blank if using host-installed cloudflared (Path 2).
CLOUDFLARE_TUNNEL_TOKEN=<paste-from-cloudflare-dashboard>

# -----------------------------------------------------------------------------
# Ingest API key (rotate before any real traffic — generate a strong random)
# -----------------------------------------------------------------------------
INGEST_API_KEY=<set-a-strong-random-key>
